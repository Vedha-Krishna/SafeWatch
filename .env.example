# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by backend/crawler/reddit_crawler.py when running with --upload
SUPABASE_KEY=your-supabase-service-role-key

# Reddit crawler user agent (optional override for CLI --user-agent)
REDDIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) OSINT-Hackathon-Bot/1.0

# Vercel Cron
# Use the same random value in the Vercel frontend project and the backend host.
CRON_SECRET=replace-with-at-least-16-random-characters

# Frontend-only: Vercel route calls this backend URL every 10 minutes.
BACKEND_CRON_URL=https://your-backend.example.com/api/cron/safewatch
BACKEND_CRON_TIMEOUT_MS=55000

# Backend-only: tune cron batch size so each run finishes inside your function/host limits.
CRON_CRAWLER_LIMIT=25
CRON_MAX_CLEANER_RUNS=5
CRON_MAX_PROCESS_INCIDENTS=5
CRON_INCLUDE_COMMENTS=false
